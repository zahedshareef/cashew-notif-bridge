    <string name="about_title">About Cashew Bridge</string>
    <string name="about_message">Cashew Bridge reads your bank/payment notifications and automatically creates transactions in the Cashew app using its App Link feature.\n\nYour notification data never leaves your device. No network access is used.\n\nVersion 1.3</string>
