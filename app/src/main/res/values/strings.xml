    <!-- Onboarding -->
    <string name="onboarding_title">Welcome to Cashew Bridge</string>
    <string name="onboarding_message">This app reads your bank and payment notifications and automatically creates transactions in Cashew.\n\n1. Grant Notification Access so this app can read alerts.\n2. (Optional) Add rules to customize how amounts and merchants are parsed.\n3. Done — transactions flow into Cashew automatically.\n\nAll processing happens on your device. No data ever leaves it.</string>
